{
  "name": "winline",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build --compile --outfile dist/winline statusline.ts",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-amd64 && bun run build:linux-arm64 && bun run build:linux-amd64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile dist/winline-darwin-arm64 statusline.ts",
    "build:darwin-amd64": "bun build --compile --target=bun-darwin-x64 --outfile dist/winline-darwin-amd64 statusline.ts",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 --outfile dist/winline-linux-arm64 statusline.ts",
    "build:linux-amd64": "bun build --compile --target=bun-linux-x64 --outfile dist/winline-linux-amd64 statusline.ts",
    "dev": "bun run statusline.ts",
    "install:local": "bun run build && cp dist/winline ~/.local/bin/winline"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "smol-toml": "^1.3.1"
  }
}
